# Copy this file to .env.local and fill in your Supabase project's values.
# Find these in the Supabase dashboard: Project Settings → API.
# The anon key is safe to expose client-side — it's designed for this and is
# protected by Row Level Security policies on every table. Never put the
# service_role secret key here or anywhere in client code.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
